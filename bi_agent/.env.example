# Monday.com API Token (from monday.com > Profile > Developers > API)
MONDAY_API_TOKEN=your_monday_api_token_here

# Monday.com Board IDs (get these after importing boards)
DEALS_BOARD_ID=your_deals_board_id_here
WORK_ORDERS_BOARD_ID=your_work_orders_board_id_here

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use via OpenRouter
OPENAI_MODEL=ModelNameHere

# Optional: your app URL and name (shown in OpenRouter dashboard)
APP_SITE_URL=http://localhost:8000
APP_SITE_NAME=Monday.com BI Agent

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false